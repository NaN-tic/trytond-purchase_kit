msgctxt "field:product.product,explode_kit_in_purchases:"
msgid "Explode in Purchases"
msgstr "Expandir en las compras"

msgctxt "field:purchase.line,kit_child_lines:"
msgid "Lines in the kit"
msgstr "Líneas del kit"

msgctxt "field:purchase.line,kit_depth:"
msgid "Depth"
msgstr "Profundidad"

msgctxt "field:purchase.line,kit_parent_line:"
msgid "Parent Kit Line"
msgstr "Padre de la línea del kit."

msgctxt "help:purchase.line,kit_child_lines:"
msgid "Subcomponents of the kit."
msgstr "Componentes del kit."

msgctxt "help:purchase.line,kit_depth:"
msgid "Depth of the line if it is part of a kit."
msgstr "Profundidad de la líniea si forma parte de un kit."

msgctxt "help:purchase.line,kit_parent_line:"
msgid "The kit that contains this product."
msgstr "El kit que contiene este producto"

msgctxt "model:ir.message,text:purchasable_lines_required"
msgid ""
"The lines of a Kit with the flag \"Explode in Purchases\" checked must be "
"\"Purchasables\"."
msgstr ""
"Las líneas de un Kit con la marca \"Expandir en las compras\" marcada deben se"
"r "
"\"Comprables\"."

msgctxt "model:ir.message,text:purchasable_product_required_in_kit"
msgid ""
"The product \"%(product)s\" has the flag \"Explode in Purchases\" checked "
"but not all the products of its lines are \"Purchasables\"."
msgstr ""
"El producto \"%(product)s\" tiene la marca \"Expandir en las compras\" marcada"
","
" pero no todos los productos de sus líneas son \"Comprables\"."
